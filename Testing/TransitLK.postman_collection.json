          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/schedules/conflicts/check?tripDate=2026-06-10&routeId={{routeId}}&busId={{busId}}&driverId={{driverId}}&departureTime=08:00&arrivalTime=10:00",
              "host": ["{{baseUrl}}"],
              "path": ["api", "schedules", "conflicts", "check"],
              "query": [
                {
                  "key": "tripDate",
                  "value": "2026-06-10"
                },
                {
                  "key": "routeId",
                  "value": "{{routeId}}"
                },
                {
                  "key": "busId",
                  "value": "{{busId}}"
                },
                {
                  "key": "driverId",
                  "value": "{{driverId}}"
                },
                {
                  "key": "departureTime",
                  "value": "08:00"
                },
                {
                  "key": "arrivalTime",
                  "value": "10:00"
                }
              ]
            },
            "description": "Set routeId, busId, driverId from List routes / buses / drivers first."
          },
          "response": []
        },
        {
          "name": "Create schedule (draft)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"routeId\": \"{{routeId}}\",\n  \"busId\": \"{{busId}}\",\n  \"driverId\": \"{{driverId}}\",\n  \"departureTime\": \"08:00\",\n  \"arrivalTime\": \"10:00\",\n  \"tripDate\": \"2026-06-10\",\n  \"status\": \"draft\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/schedules",
              "host": ["{{baseUrl}}"],
              "path": ["api", "schedules"]
            },
            "description": "Administrator or Transport Scheduler only. Fill routeId, busId, driverId variables first."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('scheduleId', pm.response.json()._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Submit schedule for approval",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/schedules/{{scheduleId}}/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "schedules", "{{scheduleId}}", "submit"]
            }
          },
          "response": []
        },
        {
          "name": "Approve schedule",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/schedules/{{scheduleId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "schedules", "{{scheduleId}}", "approve"]
            },
            "description": "Depot Manager or Administrator. Login as depot@transitlk.lk first."
          },
          "response": []
        },
        {
          "name": "Reject schedule",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Incomplete timetable — missing return leg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/schedules/{{scheduleId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["api", "schedules", "{{scheduleId}}", "reject"]
            }
          },
          "response": []
        }
      ]

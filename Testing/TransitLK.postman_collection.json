    {
      "name": "Routes",
      "item": [
        {
          "name": "List routes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/routes?summary=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes"],
              "query": [
                {
                  "key": "summary",
                  "value": "1"
                },
                {
                  "key": "status",
                  "value": "active",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    const routes = pm.response.json();",
                  "    if (Array.isArray(routes) && routes.length > 0) {",
                  "        pm.collectionVariables.set('routeId', routes[0]._id);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get route by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/routes/{{routeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes", "{{routeId}}"]
            },
            "description": "Set `routeId` from List routes, or paste a MongoDB ObjectId."
          },
          "response": []
        }
      ]
    },
